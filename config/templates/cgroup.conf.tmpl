# ===========================================================================
# cgroup.conf — Slurm cgroup resource isolation configuration
# Generated by slurm-installer on %%GENERATED_DATE%%
# ===========================================================================
# Documentation: https://slurm.schedmd.com/cgroup.conf.html
# This file is used on compute nodes.
# ===========================================================================

# Constrain CPU cores allocated to jobs
ConstrainCores=yes

# Constrain memory to allocated amount
ConstrainRAMSpace=yes

# Allow a small percentage over the memory limit before OOM kill
AllowedRAMSpace=100

# Constrain swap usage
ConstrainSwapSpace=yes
AllowedSwapSpace=0

# Constrain access to devices (GPUs, etc.)
ConstrainDevices=yes
