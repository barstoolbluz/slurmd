# Auto-detection discovers all GPUs without manual enumeration.
# NVML detects NVIDIA GPUs (requires nvidia-smi / CUDA drivers).
# RSMI detects AMD GPUs (requires rocm-smi / ROCm drivers).
# Both lines are safe to include; each only activates if the respective driver is present.
AutoDetect=nvml
AutoDetect=rsmi
