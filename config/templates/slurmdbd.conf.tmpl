# ===========================================================================
# slurmdbd.conf — Slurm database daemon configuration
# Generated by slurm-installer on %%GENERATED_DATE%%
# ===========================================================================
# Documentation: https://slurm.schedmd.com/slurmdbd.conf.html
# This file should ONLY exist on the database node.
# Permissions MUST be 0600 owned by slurm:slurm.
# ===========================================================================

# ── Daemon settings ───────────────────────────────────────────────────────

SlurmUser=slurm
DbdHost=%%DBD_HOSTNAME%%
DbdPort=6819
PidFile=/run/slurmdbd.pid

# ── Authentication ────────────────────────────────────────────────────────

AuthType=auth/munge

# ── Logging ───────────────────────────────────────────────────────────────

LogFile=/var/log/slurm/slurmdbd.log
DebugLevel=info

# ── Database connection ───────────────────────────────────────────────────

StorageType=accounting_storage/mysql
StorageHost=%%STORAGE_HOST%%
StoragePort=%%STORAGE_PORT%%
StorageLoc=%%STORAGE_DB_NAME%%
StorageUser=%%STORAGE_USER%%
StoragePass=%%STORAGE_PASS%%
